# Application
FLASK_ENV=development
FLASK_DEBUG=1

# JWT Authentication (CHANGE IN PRODUCTION)
JWT_SECRET_KEY=dev-secret-key-min-32-chars-change-me

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_career_db
DB_USER=postgres
DB_PASSWORD=your-postgres-password

# Fallback: SQLite for development
# DATABASE_URL=sqlite:///ai_career.db

# Phishing Detection APIs (Get free keys)
# VirusTotal: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_vt_key_here
# URLScan.io: https://urlscan.io/
URLSCAN_API_KEY=your_urlscan_key_here

# CORS (Frontend origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# File Uploads
MAX_UPLOAD_SIZE_MB=16
UPLOAD_FOLDER=uploads